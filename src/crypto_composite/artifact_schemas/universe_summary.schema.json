{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thanhlq8-max/crypto-composite-market-data/schemas/universe_summary.schema.json",
  "title": "Universe run summary",
  "description": "Contract for a universe_summary.json artifact. Additional object fields are allowed (the contract is additive); required fields must not be renamed or dropped.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "assets",
    "venues",
    "market_types",
    "timeframes",
    "asset_count",
    "asset_results",
    "errors",
    "outputs",
    "limitations"
  ],
  "properties": {
    "assets": {"type": "array", "items": {"type": "string"}},
    "venues": {"type": "array", "items": {"type": "string"}},
    "market_types": {"type": "array", "items": {"type": "string"}},
    "timeframes": {"type": "array", "items": {"type": "string"}},
    "asset_count": {"type": "integer"},
    "asset_results": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "description": "Per-asset result: a successful entry carries artifact_dir/outputs; a failed entry carries an error."
      }
    },
    "errors": {"type": "array"},
    "outputs": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
