{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thanhlq8-max/crypto-composite-market-data/schemas/run_summary.schema.json",
  "title": "Single-asset run summary",
  "description": "Contract for a run_summary.json artifact. Additional object fields are allowed (the contract is additive); required fields must not be renamed or dropped.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "asset",
    "venues",
    "market_types",
    "timeframes",
    "outputs",
    "data_quality_by_timeframe",
    "limitations"
  ],
  "properties": {
    "asset": {"type": "string"},
    "venues": {"type": "array", "items": {"type": "string"}},
    "market_types": {"type": "array", "items": {"type": "string"}},
    "timeframes": {"type": "array", "items": {"type": "string"}},
    "outputs": {"type": "object"},
    "data_quality_by_timeframe": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["status", "overall_quality"],
        "properties": {
          "status": {"type": "string"},
          "overall_quality": {"type": "number"}
        }
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
